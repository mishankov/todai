# Immutable release tag (for example v0.1.0) or a documented commit tag (sha-<40 hex chars>).
TODAI_VERSION=

# The only host-published application port.
TODAI_PUBLISHED_HTTP_PORT=8080

# Use a URL-safe random password, for example: openssl rand -hex 32
TODAI_POSTGRES_DB=todai
TODAI_POSTGRES_USER=todai_app
TODAI_POSTGRES_PASSWORD=

TODAI_SESSION_COOKIE_NAME=todai_session
TODAI_BACKEND_URL=http://backend:8080
TODAI_INTERNAL_API_URL=http://127.0.0.1:8080

TODAI_RUNNER_STARTUP_TIMEOUT=5s
TODAI_RUNNER_RUN_TIMEOUT=2m
TODAI_RUNNER_ABORT_TIMEOUT=2s
TODAI_RUNNER_MAX_LINE_BYTES=1048576
TODAI_AGENT_TOKEN_TTL=15m

# Keep fake for the first diagnostic start. Set pi and complete the values below for real runs.
TODAI_AGENT_RUNTIME=fake
TODAI_PI_PROVIDER=
TODAI_PI_MODEL=
TODAI_PI_MODELS=
